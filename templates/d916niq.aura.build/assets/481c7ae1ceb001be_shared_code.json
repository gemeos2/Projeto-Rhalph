data-lucide=\"activity\"></i>\n                    HR Zone 3-4\n                  </div>\n                  <div class=\"flex items-center gap-1 text-sm text-neutral-300\">\n                    <i data-lucide=\"flame\"></i>\n                    340 kcal\n                  </div>\n                </div>\n              </div>\n              <div class=\"absolute top-4 right-4 flex items-center gap-2\">\n                <span class=\"inline-flex items-center gap-1 rounded-md bg-emerald-500/10 text-emerald-300 px-2 py-1 text-[11px] ring-1 ring-emerald-500/30\">\n                  <i data-lucide=\"sparkles\"></i>\n                  Featured\n                </span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Feature Grid -->\n    <section id=\"coaching\" class=\"relative\">\n      <div class=\"mx-auto max-w-7xl px-6 py-12 md:py-16\">\n        <div class=\"grid md:grid-cols-3 gap-6\">\n          <div class=\"rounded-xl p-6 bg-neutral-900/60 ring-1 ring-white/10 hover:ring-white/20 transition\">\n            <div class=\"flex items-center gap-3\">\n              <div class=\"w-10 h-10 rounded-md bg-emerald-500/15 ring-1 ring-emerald-500/30 flex items-center justify-center text-emerald-300\">\n                <i data-lucide=\"goal\" class=\"w-5 h-5\"></i>\n              </div>\n              <h3 class=\"text-lg font-semibold tracking-tight\">Personalized Plans</h3>\n            </div>\n            <p class=\"mt-3 text-sm text-neutral-300\">Adaptive training based on your goals, experience, and recovery. Hit PRs without burning out.</p>\n            <ul class=\"mt-4 text-sm text-neutral-300 space-y-2\">\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Strength, HIIT, endurance, mobility</li>\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Auto deloads + recovery weeks</li>\n            </ul>\n          </div>\n          <div class=\"rounded-xl p-6 bg-neutral-900/60 ring-1 ring-white/10 hover:ring-white/20 transition\">\n            <div class=\"flex items-center gap-3\">\n              <div class=\"w-10 h-10 rounded-md bg-emerald-500/15 ring-1 ring-emerald-500/30 flex items-center justify-center text-emerald-300\">\n                <i data-lucide=\"mic\" class=\"w-5 h-5\"></i>\n              </div>\n              <h3 class=\"text-lg font-semibold tracking-tight\">Real‑Time Coaching</h3>\n            </div>\n            <p class=\"mt-3 text-sm text-neutral-300\">Pace cues, HR zone guidance, and form tips that keep you in the sweet spot every session.</p>\n            <ul class=\"mt-4 text-sm text-neutral-300 space-y-2\">\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Live cues for tempo & rest</li>\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Sync Apple/Google Health</li>\n            </ul>\n          </div>\n          <div class=\"rounded-xl p-6 bg-neutral-900/60 ring-1 ring-white/10 hover:ring-white/20 transition\">\n            <div class=\"flex items-center gap-3\">\n              <div class=\"w-10 h-10 rounded-md bg-emerald-500/15 ring-1 ring-emerald-500/30 flex items-center justify-center text-emerald-300\">\n                <i data-lucide=\"users\" class=\"w-5 h-5\"></i>\n              </div>\n              <h3 class=\"text-lg font-semibold tracking-tight\">Community & Challenges</h3>\n            </div>\n            <p class=\"mt-3 text-sm text-neutral-300\">Train with friends, climb leaderboards, and commit to 4‑week sprints with accountability.</p>\n            <ul class=\"mt-4 text-sm text-neutral-300 space-y-2\">\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Weekly challenges & badges</li>\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Coach Q&A and form checks</li>\n            </ul>\n          </div>\n        </div>\n      </div>\n      <div class=\"mx-auto max-w-7xl px-6\">\n        <div class=\"h-px bg-gradient-to-r from-transparent via-white/10 to-transparent\"></div>\n      </div>\n    </section>\n\n    <!-- Programs -->\n    <section id=\"programs\" class=\"relative\">\n      <div class=\"mx-auto max-w-7xl px-6 py-12 md:py-16\">\n        <div class=\"flex items-end justify-between gap-6\">\n          <div>\n            <h2 class=\"text-3xl md:text-4xl font-semibold tracking-tight\">Programs built for consistent progress</h2>\n            <p class=\"mt-2 text-neutral-300 text-sm md:text-base\">Choose your track and level up with smart progression.</p>\n          </div>\n          <a href=\"#\" class=\"hidden sm:inline-flex items-center gap-2 rounded-md px-3.5 py-2 text-sm text-neutral-200 ring-1 ring-white/10 hover:ring-white/20 hover:bg-white/5 transition\">\n            <i data-lucide=\"list-checks\"></i>\n            View all\n          </a>\n        </div>\n\n        <div class=\"mt-8 grid md:grid-cols-3 gap-6\">\n          <div class=\"group rounded-xl overflow-hidden bg-neutral-900/60 ring-1 ring-white/10 hover:ring-white/20 transition\">\n            <div class=\"relative\">\n              <img src=\"https://images.unsplash.com/photo-1621619856624-42fd193a0661?w=1080&q=80\" alt=\"HIIT\" class=\"h-48 w-full object-cover group-hover:opacity-95 transition\"/>\n              <div class=\"absolute top-3 left-3 inline-flex items-center gap-1 rounded-md bg-emerald-500/10 text-emerald-300 px-2 py-1 text-[11px] ring-1 ring-emerald-500/30\">\n                <i data-lucide=\"bolt\"></i> HIIT\n              </div>\n            </div>\n            <div class=\"p-5\">\n              <h3 class=\"text-lg font-semibold tracking-tight\">HIIT Burn 2.0</h3>\n              <p class=\"mt-1.5 text-sm text-neutral-300\">Fast intervals to spike VO₂ and torch calories. Minimal gear.</p>\n              <div class=\"mt-4 flex items-center justify-between text-xs text-neutral-300\">\n                <span class=\"inline-flex items-center gap-1\"><i data-lucide=\"clock-5\"></i> 24–30 min</span>\n                <span class=\"inline-flex items-center gap-1\"><i data-lucide=\"signal\"></i> Level 2</span>\n                <span class=\"inline-flex items-center gap-1\"><i data-lucide=\"flame\"></i> 280–420 kcal</span>\n              </div>\n              <div class=\"mt-4 flex items-center justify-between\">\n                <a href=\"#\" class=\"text-sm text-emerald-300 hover:text-emerald-200\">Start plan</a>\n                <button class=\"inline-flex items-center gap-2 rounded-md px-3 py-2 text-xs font-medium bg-emerald-500 text-neutral-950 hover:bg-emerald-400 transition\">\n                  <i data-lucide=\"plus\"></i>\n                  Add to stack\n                </button>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"group rounded-xl overflow-hidden bg-neutral-900/60 ring-1 ring-white/10 hover:ring-white/20 transition\">\n            <div class=\"relative\">\n              <img src=\"https://images.unsplash.com/photo-1507398941214-572c25f4b1dc?q=80&w=1600&auto=format&fit=crop\" alt=\"Strength\" class=\"h-48 w-full object-cover group-hover:opacity-95 transition\"/>\n              <div class=\"absolute top-3 left-3 inline-flex items-center gap-1 rounded-md bg-emerald-500/10 text-emerald-300 px-2 py-1 text-[11px] ring-1 ring-emerald-500/30\">\n                <i data-lucide=\"dumbbell\"></i> Strength\n              </div>\n            </div>\n            <div class=\"p-5\">\n              <h3 class=\"text-lg font-semibold tracking-tight\">Strength Foundation</h3>\n              <p class=\"mt-1.5 text-sm text-neutral-300\">Compound lifts, progressive overload, and rock-solid technique.</p>\n              <div class=\"mt-4 flex items-center justify-between text-xs text-neutral-300\">\n                <span class=\"inline-flex items-center gap-1\"><i data-lucide=\"clock-5\"></i> 45–60 min</span>\n                <span class=\"inline-flex items-center gap-1\"><i data-lucide=\"signal\"></i> Level 1–3</span>\n                <span class=\"inline-flex items-center gap-1\"><i data-lucide=\"target\"></i> 5x5 / 3x8</span>\n              </div>\n              <div class=\"mt-4 flex items-center justify-between\">\n                <a href=\"#\" class=\"text-sm text-emerald-300 hover:text-emerald-200\">Start plan</a>\n                <button class=\"inline-flex items-center gap-2 rounded-md px-3 py-2 text-xs font-medium bg-emerald-500 text-neutral-950 hover:bg-emerald-400 transition\">\n                  <i data-lucide=\"plus\"></i>\n                  Add to stack\n                </button>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"group rounded-xl overflow-hidden bg-neutral-900/60 ring-1 ring-white/10 hover:ring-white/20 transition\">\n            <div class=\"relative\">\n              <img src=\"https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=1600&auto=format&fit=crop\" alt=\"Mobility\" class=\"h-48 w-full object-cover group-hover:opacity-95 transition\"/>\n              <div class=\"absolute top-3 left-3 inline-flex items-center gap-1 rounded-md bg-emerald-500/10 text-emerald-300 px-2 py-1 text-[11px] ring-1 ring-emerald-500/30\">\n                <i data-lucide=\"stretch-vertical\"></i> Mobility\n              </div>\n            </div>\n            <div class=\"p-5\">\n              <h3 class=\"text-lg font-semibold tracking-tight\">Mobility Flow</h3>\n              <p class=\"mt-1.5 text-sm text-neutral-300\">Unlock range of motion and bulletproof your joints with intent.</p>\n              <div class=\"mt-4 flex items-center justify-between text-xs text-neutral-300\">\n                <span class=\"inline-flex items-center gap-1\"><i data-lucide=\"clock-5\"></i> 15–25 min</span>\n                <span class=\"inline-flex items-center gap-1\"><i data-lucide=\"signal\"></i> Level 1</span>\n                <span class=\"inline-flex items-center gap-1\"><i data-lucide=\"puzzle\"></i> Active recovery</span>\n              </div>\n              <div class=\"mt-4 flex items-center justify-between\">\n                <a href=\"#\" class=\"text-sm text-emerald-300 hover:text-emerald-200\">Start plan</a>\n                <button class=\"inline-flex items-center gap-2 rounded-md px-3 py-2 text-xs font-medium bg-emerald-500 text-neutral-950 hover:bg-emerald-400 transition\">\n                  <i data-lucide=\"plus\"></i>\n                  Add to stack\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Micro CTA -->\n        <div class=\"mt-8 rounded-xl bg-gradient-to-r from-emerald-500/10 via-cyan-500/10 to-blue-500/10 ring-1 ring-white/10 p-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-4\">\n          <div class=\"flex items-center gap-3\">\n            <div class=\"w-10 h-10 rounded-md bg-emerald-500/15 ring-1 ring-emerald-500/30 flex items-center justify-center text-emerald-300\">\n              <i data-lucide=\"trophy\"></i>\n            </div>\n            <div>\n              <h4 class=\"text-base font-semibold tracking-tight\">30‑day challenge: Build the habit</h4>\n              <p class=\"text-sm text-neutral-300\">Daily 20‑minute sessions to lock in consistency. Join now and earn a limited badge.</p>\n            </div>\n          </div>\n          <a href=\"#\" class=\"inline-flex items-center gap-2 rounded-md px-4 py-2 text-sm font-medium bg-emerald-500 text-neutral-950 hover:bg-emerald-400 transition\">\n            <i data-lucide=\"sparkles\"></i>\n            Join challenge\n          </a>\n        </div>\n      </div>\n      <div class=\"mx-auto max-w-7xl px-6\">\n        <div class=\"h-px bg-gradient-to-r from-transparent via-white/10 to-transparent\"></div>\n      </div>\n    </section>\n\n    <!-- Analytics -->\n    <section class=\"relative\">\n      <div class=\"mx-auto max-w-7xl px-6 py-12 md:py-16\">\n        <div class=\"grid lg:grid-cols-2 gap-8\">\n          <div class=\"rounded-xl bg-neutral-900/60 ring-1 ring-white/10 p-6\">\n            <div class=\"flex items-start justify-between\">\n              <div>\n                <h3 class=\"text-xl font-semibold tracking-tight\">Weekly Progress</h3>\n                <p class=\"mt-1 text-sm text-neutral-300\">Consistency drives results. Track volume, time, and intensity.</p>\n              </div>\n              <div class=\"inline-flex items-center gap-2 rounded-md px-2.5 py-1 text-[11px] text-neutral-300 ring-1 ring-white/10\">\n                <i data-lucide=\"calendar\"></i> Last 7 days\n              </div>\n            </div>\n            <div class=\"mt-4 rounded-lg bg-neutral-950/60 ring-1 ring-white/10 p-3\">\n              <div class=\"relative w-full\">\n                <div class=\"w-full\">\n                  <canvas id=\"weeklyChart\" class=\"w-full h-56\"></canvas>\n                </div>\n              </div>\n            </div>\n            <div class=\"mt-4 grid grid-cols-3 gap-3\">\n              <div class=\"rounded-lg bg-neutral-950/60 ring-1 ring-white/10 p-3\">\n                <div class=\"text-xs text-neutral-400\">Total minutes</div>\n                <div class=\"mt-1 text-lg font-semibold tracking-tight\" id=\"stat-mins\">302</div>\n              </div>\n              <div class=\"rounded-lg bg-neutral-950/60 ring-1 ring-white/10 p-3\">\n                <div class=\"text-xs text-neutral-400\">Calories</div>\n                <div class=\"mt-1 text-lg font-semibold tracking-tight\" id=\"stat-cals\">2,430</div>\n              </div>\n              <div class=\"rounded-lg bg-neutral-950/60 ring-1 ring-white/10 p-3\">\n                <div class=\"text-xs text-neutral-400\">Sessions</div>\n                <div class=\"mt-1 text-lg font-semibold tracking-tight\" id=\"stat-sessions\">6</div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"rounded-xl bg-neutral-900/60 ring-1 ring-white/10 p-6\">\n            <h3 class=\"text-xl font-semibold tracking-tight\">What athletes are saying</h3>\n            <p class=\"mt-1 text-sm text-neutral-300\">Real stories. Real progress. Join a team that shows up.</p>\n            <div class=\"mt-5 space-y-4\">\n              <div class=\"flex gap-4 p-4 rounded-lg bg-neutral-950/60 ring-1 ring-white/10\">\n                <img src=\"https://images.unsplash.com/photo-1529665253569-6d01c0eaf7b6?q=80&w=300&auto=format&fit=crop\" alt=\"member\" class=\"w-12 h-12 rounded-full object-cover\"/>\n                <div>\n                  <div class=\"flex items-center gap-2\">\n                    <span class=\"text-sm font-semibold tracking-tight\">Amina K.</span>\n                    <span class=\"text-[11px] text-emerald-300 inline-flex items-center gap-1\"><i data-lucide=\"badge-check\"></i> Verified</span>\n                  </div>\n                  <p class=\"text-sm text-neutral-300 mt-1\">“Week 3 and already stronger. The cues keep my form tight and the workouts fly.”</p>\n                </div>\n              </div>\n              <div class=\"flex gap-4 p-4 rounded-lg bg-neutral-950/60 ring-1 ring-white/10\">\n                <img src=\"https://images.unsplash.com/photo-1642615835477-d303d7dc9ee9?w=1080&q=80\" alt=\"member\" class=\"w-12 h-12 rounded-full object-cover\"/>\n                <div>\n                  <div class=\"flex items-center gap-2\">\n                    <span class=\"text-sm font-semibold tracking-tight\">Leo M.</span>\n                    <span class=\"text-[11px] text-emerald-300 inline-flex items-center gap-1\"><i data-lucide=\"badge-check\"></i> Verified</span>\n                  </div>\n                  <p class=\"text-sm text-neutral-300 mt-1\">“I finally stuck to a plan. The progression feels smart, not random.”</p>\n                </div>\n              </div>\n              <div class=\"flex gap-4 p-4 rounded-lg bg-neutral-950/60 ring-1 ring-white/10\">\n                <img src=\"https://images.unsplash.com/photo-1547425260-76bcadfb4f2c?q=80&w=300&auto=format&fit=crop\" alt=\"member\" class=\"w-12 h-12 rounded-full object-cover\"/>\n                <div>\n                  <div class=\"flex items-center gap-2\">\n                    <span class=\"text-sm font-semibold tracking-tight\">Jess P.</span>\n                    <span class=\"text-[11px] text-emerald-300 inline-flex items-center gap-1\"><i data-lucide=\"badge-check\"></i> Verified</span>\n                  </div>\n                  <p class=\"text-sm text-neutral-300 mt-1\">“Community challenges are the boost I needed. Showing up is non‑negotiable now.”</p>\n                </div>\n              </div>\n            </div>\n\n            <div id=\"community\" class=\"mt-5 flex items-center justify-between\">\n              <div class=\"flex -space-x-2\">\n                <img src=\"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=300&auto=format&fit=crop\" class=\"w-8 h-8 rounded-full ring-2 ring-neutral-900 object-cover\" alt=\"\"/>\n                <img src=\"https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=300&auto=format&fit=crop\" class=\"w-8 h-8 rounded-full ring-2 ring-neutral-900 object-cover\" alt=\"\"/>\n                <img src=\"https://images.unsplash.com/photo-1547425260-76bcadfb4f2c?q=80&w=300&auto=format&fit=crop\" class=\"w-8 h-8 rounded-full ring-2 ring-neutral-900 object-cover\" alt=\"\"/>\n                <div class=\"w-8 h-8 rounded-full ring-2 ring-neutral-900 bg-neutral-800 text-[11px] flex items-center justify-center text-neutral-300\">+8</div>\n              </div>\n              <a href=\"#\" class=\"inline-flex items-center gap-2 rounded-md px-3 py-2 text-xs text-neutral-200 ring-1 ring-white/10 hover:ring-white/20 hover:bg-white/5 transition\">\n                <i data-lucide=\"users-2\"></i>\n                Meet the community\n              </a>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"mx-auto max-w-7xl px-6\">\n        <div class=\"h-px bg-gradient-to-r from-transparent via-white/10 to-transparent\"></div>\n      </div>\n    </section>\n\n    <!-- Pricing -->\n    <section id=\"pricing\" class=\"relative\">\n      <div class=\"mx-auto max-w-7xl px-6 py-12 md:py-16\">\n        <div class=\"text-center max-w-2xl mx-auto\">\n          <h2 class=\"text-3xl md:text-4xl font-semibold tracking-tight\">Pick your momentum</h2>\n          <p class=\"mt-2 text-neutral-300 text-sm md:text-base\">Start free. Upgrade when you’re ready to go all‑in.</p>\n        </div>\n\n        <div class=\"mt-8 grid md:grid-cols-3 gap-6\">\n          <!-- Starter -->\n          <div class=\"rounded-2xl p-6 bg-neutral-900/60 ring-1 ring-white/10 hover:ring-white/20 transition flex flex-col\">\n            <div class=\"flex items-center justify-between\">\n              <h3 class=\"text-lg font-semibold tracking-tight\">Starter</h3>\n            </div>\n            <div class=\"mt-2 text-3xl font-semibold tracking-tight\">$0<span class=\"text-sm text-neutral-400\">/mo</span></div>\n            <ul class=\"mt-4 space-y-2 text-sm text-neutral-300\">\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>3 programs</li>\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Basic tracking</li>\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"x\" class=\"text-neutral-500\"></i>Community challenges</li>\n            </ul>\n            <a href=\"#\" class=\"mt-6 inline-flex items-center justify-center gap-2 rounded-md px-4 py-2 text-sm text-neutral-200 ring-1 ring-white/10 hover:ring-white/20 hover:bg-white/5 transition\">Get started</a>\n          </div>\n\n          <!-- Pro -->\n          <div class=\"relative rounded-2xl p-6 bg-neutral-800/60 ring-2 ring-emerald-500/40 hover:ring-emerald-400/60 transition flex flex-col\">\n            <div class=\"absolute -top-3 left-6 inline-flex items-center gap-1 rounded-md bg-emerald-500 text-neutral-950 px-2.5 py-1 text-[11px] font-medium\">\n              <i data-lucide=\"sparkles\"></i> Most popular\n            </div>\n            <div class=\"flex items-center justify-between\">\n              <h3 class=\"text-lg font-semibold tracking-tight\">Pro</h3>\n            </div>\n            <div class=\"mt-2 text-3xl font-semibold tracking-tight\">$19<span class=\"text-sm text-neutral-300\">/mo</span></div>\n            <ul class=\"mt-4 space-y-2 text-sm text-neutral-200\">\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Unlimited programs</li>\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Real‑time coaching</li>\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Community challenges</li>\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Health sync + analytics</li>\n            </ul>\n            <a href=\"#\" class=\"mt-6 inline-flex items-center justify-center gap-2 rounded-md px-4 py-2 text-sm font-medium bg-emerald-500 text-neutral-950 hover:bg-emerald-400 transition\">Upgrade to Pro</a>\n          </div>\n\n          <!-- Elite -->\n          <div class=\"rounded-2xl p-6 bg-neutral-900/60 ring-1 ring-white/10 hover:ring-white/20 transition flex flex-col\">\n            <div class=\"flex items-center justify-between\">\n              <h3 class=\"text-lg font-semibold tracking-tight\">Elite</h3>\n            </div>\n            <div class=\"mt-2 text-3xl font-semibold tracking-tight\">$49<span class=\"text-sm text-neutral-400\">/mo</span></div>\n            <ul class=\"mt-4 space-y-2 text-sm text-neutral-300\">\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>1:1 coach access</li>\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Form checks + custom tweaks</li>\n              <li class=\"flex items-center gap-2\"><i data-lucide=\"check\" class=\"text-emerald-400\"></i>Priority support</li>\n            </ul>\n            <a href=\"#\" class=\"mt-6 inline-flex items-center justify-center gap-2 rounded-md px-4 py-2 text-sm text-neutral-200 ring-1 ring-white/10 hover:ring-white/20 hover:bg-white/5 transition\">Go Elite</a>\n          </div>\n        </div>\n      </div>\n      <div class=\"mx-auto max-w-7xl px-6\">\n        <div class=\"h-px bg-gradient-to-r from-transparent via-white/10 to-transparent\"></div>\n      </div>\n    </section>\n\n    <!-- FAQ -->\n    <section id=\"faq\" class=\"relative\">\n      <div class=\"mx-auto max-w-4xl px-6 py-12 md:py-16\">\n        <h2 class=\"text-3xl md:text-4xl font-semibold tracking-tight text-center\">Questions, answered</h2>\n        <div class=\"mt-8 space-y-3\">\n          <details class=\"group rounded-lg ring-1 ring-white/10 open:ring-white/20 bg-neutral-900/60 open:bg-neutral-900/70 transition\">\n            <summary class=\"flex cursor-pointer items-center justify-between gap-3 px-5 py-4 text-sm\">\n              <span>How does the free trial work?</span>\n              <i data-lucide=\"chevron-down\" class=\"transition duration-200 group-open:rotate-180\"></i>\n            </summary>\n            <div class=\"px-5 pb-4 pt-0 text-sm text-neutral-300\">\n              Enjoy full access for 7 days. Cancel anytime from settings—no questions asked.\n            </div>\n          </details>\n          <details class=\"group rounded-lg ring-1 ring-white/10 open:ring-white/20 bg-neutral-900/60 open:bg-neutral-900/70 transition\">\n            <summary class=\"flex cursor-pointer items-center justify-between gap-3 px-5 py-4 text-sm\">\n              <span>What equipment do I need?</span>\n              <i data-lucide=\"chevron-down\" class=\"transition duration-200 group-open:rotate-180\"></i>\n            </summary>\n            <div class=\"px-5 pb-4 pt-0 text-sm text-neutral-300\">\n              Bodyweight options are available. For strength tracks, a pair of dumbbells or a barbell is ideal.\n            </div>\n          </details>\n          <details class=\"group rounded-lg ring-1 ring-white/10 open:ring-white/20 bg-neutral-900/60 open:bg-neutral-900/70 transition\">\n            <summary class=\"flex cursor-pointer items-center justify-between gap-3 px-5 py-4 text-sm\">\n              <span>Can I train around injuries?</span>\n              <i data-lucide=\"chevron-down\" class=\"transition duration-200 group-open:rotate-180\"></i>\n            </summary>\n            <div class=\"px-5 pb-4 pt-0 text-sm text-neutral-300\">\n              Yes—swap movements, lower impact options, and mobility‑first sessions are built in. Consult a pro for medical advice.\n            </div>\n          </details>\n        </div>\n      </div>\n    </section>\n\n    <!-- Newsletter / Footer -->\n    <footer class=\"relative\">\n      <div class=\"mx-auto max-w-7xl px-6 py-12 md:py-16\">\n        <div class=\"rounded-2xl bg-neutral-900/60 ring-1 ring-white/10 p-6 md:p-8\">\n          <div class=\"grid md:grid-cols-2 gap-8\">\n            <div>\n              <div class=\"flex items-center gap-3\">\n                <div class=\"flex items-center justify-center w-9 h-9 rounded-md bg-neutral-900 ring-1 ring-white/10\">\n                  <span class=\"text-emerald-400 font-semibold tracking-tight text-lg leading-none\">FX</span>\n                </div>\n                <h3 class=\"text-xl font-semibold tracking-tight\">Level up your inbox</h3>\n              </div>\n              <p class=\"mt-2 text-sm text-neutral-300\">Weekly training tips, programs, and challenges—no fluff.</p>\n            </div>\n            <form class=\"flex flex-col sm:flex-row gap-3\">\n              <input type=\"email\" placeholder=\"you@domain.com\" class=\"w-full rounded-md bg-neutral-950/60 ring-1 ring-white/10 px-3 py-2 text-sm placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50\"/>\n              <button type=\"submit\" class=\"inline-flex items-center justify-center gap-2 rounded-md px-4 py-2 text-sm font-medium bg-emerald-500 text-neutral-950 hover:bg-emerald-400 transition\">\n                <i data-lucide=\"mail\"></i>\n                Subscribe\n              </button>\n            </form>\n          </div>\n          <div class=\"mt-6 h-px bg-white/10\"></div>\n          <div class=\"mt-6 flex flex-col md:flex-row items-center justify-between gap-4\">\n            <p class=\"text-xs text-neutral-400\">© <span id=\"year\"></span> FITX. Train with intent.</p>\n            <div class=\"flex items-center gap-4 text-neutral-300\">\n              <a href=\"#\" class=\"inline-flex items-center gap-1 text-xs hover:text-white transition\"><i data-lucide=\"circle-user\"></i> Account</a>\n              <a href=\"#\" class=\"inline-flex items-center gap-1 text-xs hover:text-white transition\"><i data-lucide=\"shield\"></i> Privacy</a>\n              <a href=\"#\" class=\"inline-flex items-center gap-1 text-xs hover:text-white transition\"><i data-lucide=\"file-text\"></i> Terms</a>\n              <a href=\"#\" class=\"inline-flex items-center gap-1 text-xs hover:text-white transition\"><i data-lucide=\"instagram\"></i> Social</a>\n            </div>\n          </div>\n        </div>\n      </div>\n    </footer>\n\n    <!-- Scripts -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <script>\n      // Icons\n      lucide.createIcons({\n        attrs: { stroke: \"currentColor\", \"stroke-width\": 1.5, class: \"w-4 h-4\" }\n      });\n\n      // Year\n      document.getElementById('year').textContent = new Date().getFullYear();\n\n      // Chart\n      const ctx = document.getElementById('weeklyChart').getContext('2d');\n      const gradient = ctx.createLinearGradient(0, 0, 0, 200);\n      gradient.addColorStop(0, 'rgba(16, 185, 129, 0.35)');\n      gradient.addColorStop(1, 'rgba(16, 185, 129, 0.02)');\n\n      const data = {\n        labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],\n        datasets: [{\n          label: 'Minutes',\n          data: [38, 52, 46, 0, 61, 64, 41],\n          fill: true,\n          backgroundColor: gradient,\n          borderColor: 'rgb(16, 185, 129)',\n          tension: 0.35,\n          pointBackgroundColor: 'rgb(16, 185, 129)',\n          pointBorderColor: 'rgb(16, 185, 129)',\n          pointRadius: 3\n        }]\n      };\n\n      new Chart(ctx, {\n        type: 'line',\n        data,\n        options: {\n          responsive: true,\n          maintainAspectRatio: false,\n          scales: {\n            x: {\n              grid: { color: 'rgba(255,255,255,0.05)' },\n              ticks: { color: 'rgba(229,229,229,0.8)', font: { size: 11 } }\n            },\n            y: {\n              grid: { color: 'rgba(255,255,255,0.05)' },\n              ticks: { color: 'rgba(229,229,229,0.8)', font: { size: 11 } },\n              suggestedMax: 80\n            }\n          },\n          plugins: {\n            legend: { display: false },\n            tooltip: {\n              backgroundColor: 'rgba(15, 23, 42, 0.95)',\n              borderColor: 'rgba(255,255,255,0.08)',\n              borderWidth: 1,\n              titleColor: '#E5E7EB',\n              bodyColor: '#E5E7EB',\n              padding: 10,\n              displayColors: false,\n              callbacks: {\n                label: (ctx) => ` ${ctx.parsed.y} min`\n              }\n            }\n          },\n          elements: {\n            line: { borderWidth: 2 }\n          }\n        }\n      });\n    </script>\n  </body>\n</html>","language":"html","username":"66a84ecf-0972-40f3-8a4c-15b11d3aee0a","created_at":"2025-08-13T19:30:35.249566+00:00","views":976,"image_url":"https://hoirqrkdgbmvpwutwuwj-all.supabase.co/storage/v1/object/public/preview-images/D916NIQ.png","forks":23,"private":false,"watermark":true,"featured":true,"share_source_code":true,"user_id":"66a84ecf-0972-40f3-8a4c-15b11d3aee0a","category":"Web","updated_at":null,"tags":["Hero","Landing Page","Tailwind CSS","Responsive","Navigation","Call-To-Action","Fitness UI"],"description":"Responsive fitness landing page with hero section, navigation, stats, and call-to-action buttons using Tailwind CSS.","premium":false,"price":null,"purchase_url":null,"long_description":null,"custom_domain":null,"favicon_light_url":null,"favicon_dark_url":null,"dns_verified":null,"dns_verified_at":null,"dns_a_record":null,"netlify_apex_exists":null,"netlify_www_exists":null,"netlify_verified_at":null,"custom_domain_added_at":null,"netlify_site_id":null,"umami_website_id":null,"umami_share_id":null,"analytics_enabled":false,"gtm_container_id":null,"remix_source":{},"credit_remix_source":false}]